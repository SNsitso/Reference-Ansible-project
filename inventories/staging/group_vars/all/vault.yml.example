---
# Modèle de vault STAGING - à copier puis CHIFFRER, ne jamais committer en clair.
#
# 1. Copier :   cp vault.yml.example vault.yml
# 2. Éditer les valeurs ci-dessous
# 3. Chiffrer : ansible-vault encrypt inventories/staging/group_vars/all/vault.yml
#
# Exécution :  ansible-playbook site.yml -i inventories/staging --ask-vault-pass
#
# Mêmes NOMS de variables qu'en production, VALEURS propres au staging.

vault_mysql_root_password: "StagingRootPassword123!"
vault_mysql_app_password: "StagingAppPassword456!"
vault_prestashop_admin_password: "StagingAdminPassword789!"
